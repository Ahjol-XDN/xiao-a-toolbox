<UserControl x:Class="XiaoAToolbox.Views.DocumentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:XiaoAToolbox.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <!-- 拖放区域 -->
            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="2" CornerRadius="12"
                    Background="{StaticResource BgSubtleBrush}" Padding="32" Margin="0,0,0,16"
                    AllowDrop="True" Drop="OnDrop">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="拖放文档文件到此处，或点击选择"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,8" />
                    <Button Content="选择文件" Command="{Binding AddFilesCommand}"
                            Background="{StaticResource AccentBrush}" Foreground="White"
                            BorderThickness="0" Padding="16,8" HorizontalAlignment="Center">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8" /></Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>

            <!-- 状态提示 -->
            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="13" Margin="0,0,0,12" />

            <!-- 文件列表 -->
            <ItemsControl ItemsSource="{Binding Files}" Margin="0,0,0,16">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                                CornerRadius="8" Padding="12,8" Margin="0,2" Background="{StaticResource BgCardBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="📄" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <Button Grid.Column="2" Content="✕" Background="Transparent"
                                        Foreground="{StaticResource TextTertiaryBrush}" BorderThickness="0"
                                        Click="RemoveFile" Tag="{Binding Path}" FontSize="12" Padding="4"
                                        VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 参数区域 -->
            <Border BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="20" Background="{StaticResource BgCardBrush}" Margin="0,0,0,16">
                <StackPanel>
                    <!-- 输出格式 -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="输出格式" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12" Margin="0,0,0,6" />
                        <ComboBox Text="{Binding Format}" Padding="8,6"
                                  Background="{StaticResource BgSecondaryBrush}" BorderBrush="{StaticResource BorderBrush}">
                            <ComboBoxItem>pdf</ComboBoxItem>
                            <ComboBoxItem>docx</ComboBoxItem>
                            <ComboBoxItem>html</ComboBoxItem>
                            <ComboBoxItem>md</ComboBoxItem>
                            <ComboBoxItem>txt</ComboBoxItem>
                            <ComboBoxItem>rtf</ComboBoxItem>
                            <ComboBoxItem>epub</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>

                    <CheckBox Content="包含目录" IsChecked="{Binding IncludeToc}"
                              Margin="0,0,0,12" Foreground="{StaticResource TextPrimaryBrush}" />

                    <!-- 输出目录 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding OutputDir}" Padding="8,6"
                                 Background="{StaticResource BgSecondaryBrush}" BorderBrush="{StaticResource BorderBrush}"
                                 IsReadOnly="True" />
                        <Button Grid.Column="1" Content="浏览..." Command="{Binding BrowseOutputCommand}"
                                Padding="12,6" Margin="8,0,0,0" Background="{StaticResource BgSecondaryBrush}"
                                BorderBrush="{StaticResource BorderBrush}" Foreground="{StaticResource TextPrimaryBrush}">
                            <Button.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="6" /></Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 进度条 -->
            <Border Visibility="{Binding Running, Converter={StaticResource BoolToVis}}"
                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="12" Margin="0,0,0,12" Background="{StaticResource BgCardBrush}">
                <StackPanel>
                    <TextBlock Text="{Binding ProgressText}" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13" Margin="0,0,0,6" />
                    <ProgressBar Value="{Binding Progress}" Height="6" />
                </StackPanel>
            </Border>

            <!-- 结果统计 -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Foreground="{StaticResource SuccessBrush}" FontSize="13">
                    <Run Text="成功 " /><Run Text="{Binding SuccessCount}" /><Run Text=" 个" />
                </TextBlock>
                <TextBlock Margin="16,0,0,0" Foreground="{StaticResource ErrorBrush}" FontSize="13">
                    <Run Text="失败 " /><Run Text="{Binding FailCount}" /><Run Text=" 个" />
                </TextBlock>
            </StackPanel>

            <!-- 操作按钮 -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Content="开始转换" Command="{Binding StartCommand}"
                        Background="{StaticResource AccentDarkBrush}" Foreground="White"
                        BorderThickness="0" Padding="0,12">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="10" /></Style>
                    </Button.Resources>
                </Button>
                <Button Grid.Column="2" Content="清空" Command="{Binding ClearFilesCommand}"
                        Background="{StaticResource BgSecondaryBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                        BorderBrush="{StaticResource BorderBrush}" Padding="0,12">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="10" /></Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
