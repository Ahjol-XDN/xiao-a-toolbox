<Window x:Class="XiaoAToolbox.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:XiaoAToolbox.Views"
        xmlns:viewmodels="clr-namespace:XiaoAToolbox.ViewModels"
        Title="XiaoA Toolbox 2.1"
        Width="1100" Height="750"
        MinWidth="960" MinHeight="640"
        Background="{StaticResource BgPrimaryBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <viewmodels:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarBgBrush}" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,1,0">
            <StackPanel Margin="0,16,0,0">
                <StackPanel Margin="20,0,20,24">
                    <TextBlock Text="XiaoA Toolbox" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="v2.1" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" Margin="2,0,0,0"/>
                </StackPanel>

                <ItemsControl ItemsSource="{Binding NavItems}" Margin="8,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12,10" Margin="0,1" CornerRadius="8"
                                    Cursor="Hand" MouseLeftButtonDown="OnNavClick" Tag="{Binding PageName}"
                                    Background="Transparent">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" VerticalAlignment="Center">
                                        <Run Text="{Binding DisplayText, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="{StaticResource BgPrimaryBrush}">
            <ContentControl Content="{Binding CurrentPage}">
                <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type viewmodels:VideoViewModel}">
                        <views:VideoView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:AudioViewModel}">
                        <views:AudioView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:DocumentViewModel}">
                        <views:DocumentView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:ImageViewModel}">
                        <views:ImageView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:PdfViewModel}">
                        <views:PdfView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:BatchViewModel}">
                        <views:BatchView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:SettingsViewModel}">
                        <views:SettingsView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:AboutViewModel}">
                        <views:AboutView/>
                    </DataTemplate>
                </ContentControl.Resources>
            </ContentControl>
        </Border>
    </Grid>
</Window>
