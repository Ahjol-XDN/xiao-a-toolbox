<UserControl x:Class="XiaoAToolbox.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="设置" FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24"/>

            <!-- 主题 -->
            <Border BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="12"
                    Padding="20" Background="{StaticResource BgCardBrush}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="主题" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" Margin="0,0,0,8"/>
                    <ComboBox Text="{Binding Theme}" Padding="8,6"
                              Background="{StaticResource BgSecondaryBrush}"
                              BorderBrush="{StaticResource BorderBrush}" Width="200">
                        <ComboBoxItem>auto</ComboBoxItem>
                        <ComboBoxItem>light</ComboBoxItem>
                        <ComboBoxItem>dark</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- 语言 -->
            <Border BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="12"
                    Padding="20" Background="{StaticResource BgCardBrush}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="语言" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" Margin="0,0,0,8"/>
                    <ComboBox Text="{Binding Language}" Padding="8,6"
                              Background="{StaticResource BgSecondaryBrush}"
                              BorderBrush="{StaticResource BorderBrush}" Width="200">
                        <ComboBoxItem>zh-CN</ComboBoxItem>
                        <ComboBoxItem>en-US</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- 默认输出目录 -->
            <Border BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="12"
                    Padding="20" Background="{StaticResource BgCardBrush}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="默认输出目录" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding OutputDir}" Padding="8,6"
                                 Background="{StaticResource BgSecondaryBrush}"
                                 BorderBrush="{StaticResource BorderBrush}" IsReadOnly="True"/>
                        <Button Grid.Column="1" Content="浏览..."
                                Command="{Binding BrowseOutputCommand}"
                                Padding="12,6" Margin="8,0,0,0"
                                Background="{StaticResource BgSecondaryBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                Foreground="{StaticResource TextPrimaryBrush}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 完成通知 -->
            <Border BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="12"
                    Padding="20" Background="{StaticResource BgCardBrush}" Margin="0,0,0,16">
                <CheckBox Content="完成时通知" IsChecked="{Binding NotifyComplete}"
                          Foreground="{StaticResource TextPrimaryBrush}"/>
            </Border>

            <!-- 转换历史 -->
            <Border BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="12"
                    Padding="20" Background="{StaticResource BgCardBrush}" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="转换历史" Foreground="{StaticResource TextPrimaryBrush}"
                                   FontWeight="SemiBold"/>
                        <Button Grid.Column="1" Content="清空历史"
                                Command="{Binding ClearHistoryCommand}"
                                Background="Transparent"
                                Foreground="{StaticResource ErrorBrush}"
                                BorderThickness="0"/>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding HistoryList}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6" Margin="0,1"
                                        Background="{StaticResource BgSubtleBrush}"
                                        CornerRadius="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Success}"/>
                                        <StackPanel Grid.Column="1" Margin="8,0">
                                            <TextBlock Text="{Binding InputFile}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="300"/>
                                            <TextBlock Foreground="{StaticResource TextTertiaryBrush}"
                                                       FontSize="11">
                                                <Run Text="{Binding Operation}"/>
                                                <Run Text=" → "/>
                                                <Run Text="{Binding Format}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Timestamp, StringFormat={}{0:MM-dd HH:mm}}"
                                                   Foreground="{StaticResource TextTertiaryBrush}"
                                                   FontSize="11" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- 关于 -->
            <Border BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="12"
                    Padding="20" Background="{StaticResource BgCardBrush}">
                <StackPanel>
                    <TextBlock Text="关于" Foreground="{StaticResource TextPrimaryBrush}"
                               FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13" LineHeight="22">
                        小A万能转换工具箱 v2.1.1<LineBreak/>
                        本项目基于 FFmpeg 和 Pandoc<LineBreak/>
                        使用 .NET 8 WPF 构建
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
