<UserControl x:Class="XiaoAToolbox.Views.PdfView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:XiaoAToolbox.Converters">
    <UserControl.Resources><converters:BoolToVisibilityConverter x:Key="BoolToVis"/></UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <RadioButton Content="PDF 合并" IsChecked="True" Margin="0,0,12,0" GroupName="PdfMode" Click="OnMergeChecked"/>
                <RadioButton Content="PDF 拆分" GroupName="PdfMode" Click="OnSplitChecked"/>
            </StackPanel>

            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="2" CornerRadius="12" Background="{StaticResource BgSubtleBrush}" Padding="32" Margin="0,0,0,16" AllowDrop="True" Drop="OnDrop">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="拖拽PDF文件到此处" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <Button Content="选择文件" Command="{Binding AddFilesCommand}" Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0" Padding="16,8" HorizontalAlignment="Center">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                    </Button>
                </StackPanel>
            </Border>

            <ItemsControl ItemsSource="{Binding Files}" Margin="0,0,0,16">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,2" Background="{StaticResource BgCardBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="📑" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                <Button Grid.Column="2" Content="✕" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextTertiaryBrush}" FontSize="12" Padding="4" Click="RemoveFile" Tag="{Binding Path}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="12" Padding="20" Background="{StaticResource BgCardBrush}" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Margin="0,0,0,12"><TextBlock Text="页码范围（逗号分隔，如: 1-3,5-7）" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding PageRanges}" Padding="8,6" Background="{StaticResource BgSecondaryBrush}" BorderBrush="{StaticResource BorderBrush}"/>
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox Text="{Binding OutputDir}" Padding="8,6" Background="{StaticResource BgSecondaryBrush}" BorderBrush="{StaticResource BorderBrush}" IsReadOnly="True"/>
                        <Button Grid.Column="1" Content="浏览..." Command="{Binding BrowseOutputCommand}" Padding="12,6" Margin="8,0,0,0" Background="{StaticResource BgSecondaryBrush}" BorderBrush="{StaticResource BorderBrush}" Foreground="{StaticResource TextPrimaryBrush}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,12" Visibility="{Binding Running, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                <TextBlock Foreground="{StaticResource SuccessBrush}" FontSize="13"><Run Text="成功 "/><Run Text="{Binding OkCount}"/><Run Text=" 个"/></TextBlock>
                <TextBlock Margin="16,0,0,0" Foreground="{StaticResource ErrorBrush}" FontSize="13"><Run Text="失败 "/><Run Text="{Binding FailCount}"/><Run Text=" 个"/></TextBlock>
            </StackPanel>

            <Button Content="开始处理" Command="{Binding StartCommand}" Background="{StaticResource AccentDarkBrush}" Foreground="White" BorderThickness="0" Padding="0,12">
                <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="10"/></Style></Button.Resources>
            </Button>
        </StackPanel>
    </ScrollViewer>
</UserControl>
