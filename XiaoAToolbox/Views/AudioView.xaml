<UserControl x:Class="XiaoAToolbox.Views.AudioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:XiaoAToolbox.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <!-- Mode -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <RadioButton Content="格式转换" IsChecked="True" Margin="0,0,12,0" />
                <RadioButton Content="音频合并" Margin="0,0,12,0" GroupName="AudioMode" Click="OnMergeChecked" />
                <RadioButton Content="音频裁剪" GroupName="AudioMode" Click="OnTrimChecked" />
            </StackPanel>

            <!-- Drop Zone -->
            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="2" CornerRadius="12"
                    Background="{StaticResource BgSubtleBrush}" Padding="32" Margin="0,0,0,16"
                    AllowDrop="True" Drop="OnDrop">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="拖拽音频文件到此处，或点击选择" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,8" />
                    <Button Content="选择文件" Command="{Binding AddFilesCommand}"
                            Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0" Padding="16,8" HorizontalAlignment="Center">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8" /></Style></Button.Resources>
                    </Button>
                </StackPanel>
            </Border>

            <!-- File List -->
            <ItemsControl ItemsSource="{Binding Files}" Margin="0,0,0,16">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="8"
                                Padding="12,8" Margin="0,2" Background="{StaticResource BgCardBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Text="🎵" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="{Binding SizeDisplay}" Margin="12,0" Foreground="{StaticResource TextTertiaryBrush}" FontSize="12" VerticalAlignment="Center" />
                                <Button Grid.Column="3" Content="✕" Background="Transparent" BorderThickness="0"
                                        Foreground="{StaticResource TextTertiaryBrush}" FontSize="12" Padding="4"
                                        Click="RemoveFile" Tag="{Binding Path}" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Params -->
            <Border BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="12"
                    Padding="20" Background="{StaticResource BgCardBrush}" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="输出格式" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6" />
                        <ComboBox Text="{Binding Format}" Padding="8,6" Background="{StaticResource BgSecondaryBrush}" BorderBrush="{StaticResource BorderBrush}">
                            <ComboBoxItem>mp3</ComboBoxItem><ComboBoxItem>wav</ComboBoxItem><ComboBoxItem>aac</ComboBoxItem>
                            <ComboBoxItem>flac</ComboBoxItem><ComboBoxItem>ogg</ComboBoxItem><ComboBoxItem>wma</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="16" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="码率" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6" />
                            <ComboBox Text="{Binding Bitrate}" Padding="8,6" Background="{StaticResource BgSecondaryBrush}" BorderBrush="{StaticResource BorderBrush}">
                                <ComboBoxItem>128k</ComboBoxItem><ComboBoxItem>192k</ComboBoxItem><ComboBoxItem>256k</ComboBoxItem><ComboBoxItem>320k</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="采样率" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6" />
                            <ComboBox Text="{Binding SampleRate}" Padding="8,6" Background="{StaticResource BgSecondaryBrush}" BorderBrush="{StaticResource BorderBrush}">
                                <ComboBoxItem>22050</ComboBoxItem><ComboBoxItem>44100</ComboBoxItem><ComboBoxItem>48000</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBox Text="{Binding OutputDir}" Padding="8,6" Background="{StaticResource BgSecondaryBrush}" BorderBrush="{StaticResource BorderBrush}" IsReadOnly="True" />
                        <Button Grid.Column="1" Content="浏览..." Command="{Binding BrowseOutputCommand}" Padding="12,6" Margin="8,0,0,0" Background="{StaticResource BgSecondaryBrush}" BorderBrush="{StaticResource BorderBrush}" Foreground="{StaticResource TextPrimaryBrush}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Progress -->
            <Border Visibility="{Binding Running, Converter={StaticResource BoolToVis}}" BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12" Background="{StaticResource BgCardBrush}">
                <StackPanel>
                    <TextBlock Text="{Binding ProgressText}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" Margin="0,0,0,6" />
                    <ProgressBar Value="{Binding Progress}" Height="6" />
                </StackPanel>
            </Border>

            <!-- Results -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12" Visibility="{Binding Running, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                <TextBlock Foreground="{StaticResource SuccessBrush}" FontSize="13"><Run Text="成功 "/><Run Text="{Binding OkCount}"/><Run Text=" 个"/></TextBlock>
                <TextBlock Margin="16,0,0,0" Foreground="{StaticResource ErrorBrush}" FontSize="13"><Run Text="失败 "/><Run Text="{Binding FailCount}"/><Run Text=" 个"/></TextBlock>
            </StackPanel>

            <!-- Start Button -->
            <Button Content="开始转换" Command="{Binding StartCommand}" Background="{StaticResource AccentDarkBrush}"
                    Foreground="White" BorderThickness="0" Padding="0,12">
                <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="10" /></Style></Button.Resources>
            </Button>
        </StackPanel>
    </ScrollViewer>
</UserControl>
