<UserControl x:Class="XiaoAToolbox.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="璁剧疆" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24"/>

            <!-- Theme -->
            <Border BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="12" Padding="20" Background="{StaticResource BgCardBrush}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="涓婚" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8"/>
                    <ComboBox Text="{Binding Theme}" Padding="8,6" Background="{StaticResource BgSecondaryBrush}" BorderBrush="{StaticResource BorderBrush}" Width="200">
                        <ComboBoxItem>auto</ComboBoxItem><ComboBoxItem>light</ComboBoxItem><ComboBoxItem>dark</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- Language -->
            <Border BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="12" Padding="20" Background="{StaticResource BgCardBrush}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="璇█" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8"/>
                    <ComboBox Text="{Binding Language}" Padding="8,6" Background="{StaticResource BgSecondaryBrush}" BorderBrush="{StaticResource BorderBrush}" Width="200">
                        <ComboBoxItem>zh-CN</ComboBoxItem><ComboBoxItem>en-US</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- Output Directory -->
            <Border BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="12" Padding="20" Background="{StaticResource BgCardBrush}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="榛樿杈撳嚭鐩綍" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox Text="{Binding OutputDir}" Padding="8,6" Background="{StaticResource BgSecondaryBrush}" BorderBrush="{StaticResource BorderBrush}" IsReadOnly="True"/>
                        <Button Grid.Column="1" Content="娴忚..." Command="{Binding BrowseOutputCommand}" Padding="12,6" Margin="8,0,0,0" Background="{StaticResource BgSecondaryBrush}" BorderBrush="{StaticResource BorderBrush}" Foreground="{StaticResource TextPrimaryBrush}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Notify -->
            <Border BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="12" Padding="20" Background="{StaticResource BgCardBrush}" Margin="0,0,0,16">
                <CheckBox Content="瀹屾垚鏃堕€氱煡" IsChecked="{Binding NotifyComplete}" Foreground="{StaticResource TextPrimaryBrush}"/>
            </Border>

            <!-- History -->
            <Border BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="12" Padding="20" Background="{StaticResource BgCardBrush}" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Text="杞崲鍘嗗彶" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                        <Button Grid.Column="1" Content="娓呯┖鍘嗗彶" Command="{Binding ClearHistoryCommand}" Background="Transparent" Foreground="{StaticResource ErrorBrush}" BorderThickness="0"/>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding HistoryList}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6" Margin="0,1" Background="{StaticResource BgSubtleBrush}" CornerRadius="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Success, Converter={x:Null}}"/>
                                        <StackPanel Grid.Column="1" Margin="8,0">
                                            <TextBlock Text="{Binding InputFile}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" TextTrimming="CharacterEllipsis" MaxWidth="300"/>
                                            <TextBlock Foreground="{StaticResource TextTertiaryBrush}" FontSize="11"><Run Text="{Binding Operation}"/><Run Text=" 鈫?"/><Run Text="{Binding Format}"/></TextBlock>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding Timestamp, StringFormat={}{0:MM-dd HH:mm}}" Foreground="{StaticResource TextTertiaryBrush}" FontSize="11" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- About -->
            <Border BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="12" Padding="20" Background="{StaticResource BgCardBrush}">
                <StackPanel>
                    <TextBlock Text="鍏充簬" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" LineHeight="22">
                        灏廇涓囪兘杞崲宸ュ叿绠?3.0<LineBreak/>
                        瀹屽叏鏈湴杩愯鐨勬枃浠舵牸寮忚浆鎹㈠伐鍏?LineBreak/>
                        鍩轰簬 .NET 8 WPF 鏋勫缓
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
