<UserControl x:Class="XiaoAToolbox.Views.VideoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:XiaoAToolbox.Converters">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <!-- Mode Selector -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <RadioButton Content="格式转换" IsChecked="True" Margin="0,0,12,0"
                             GroupName="Mode" Click="OnModeConvert" />
                <RadioButton Content="视频压缩" Margin="0,0,12,0"
                             GroupName="Mode" Click="OnModeCompress" />
                <RadioButton Content="视频裁剪" Margin="0,0,12,0"
                             GroupName="Mode" Click="OnModeTrim" />
                <RadioButton Content="转GIF" Margin="0,0,12,0"
                             GroupName="Mode" Click="OnModeGif" />
                <RadioButton Content="视频截图"
                             GroupName="Mode" Click="OnModeScreenshot" />
            </StackPanel>

            <!-- Drop Zone -->
            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="2" CornerRadius="12"
                    Background="{StaticResource BgSubtleBrush}" Padding="32" Margin="0,0,0,16"
                    AllowDrop="True" Drop="OnDrop">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="拖拽视频文件到此处，或点击选择" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,8" />
                    <Button Content="选择文件" Command="{Binding AddFilesCommand}"
                            Background="{StaticResource AccentBrush}" Foreground="White"
                            BorderThickness="0" Padding="16,8" HorizontalAlignment="Center">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8" /></Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>

            <!-- File List -->
            <ItemsControl ItemsSource="{Binding Files}" Margin="0,0,0,16">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                                CornerRadius="8" Padding="12,8" Margin="0,2" Background="{StaticResource BgCardBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="🎬" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Grid.Column="2" Text="{Binding SizeDisplay}" Margin="12,0"
                                           Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center" FontSize="12" />
                                <Button Grid.Column="3" Content="✕" Background="Transparent"
                                        Foreground="{StaticResource TextTertiaryBrush}" BorderThickness="0"
                                        Click="RemoveFile" Tag="{Binding Path}" FontSize="12" Padding="4" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Params Area -->
            <Border BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="20" Background="{StaticResource BgCardBrush}" Margin="0,0,0,16">
                <StackPanel>
                    <!-- Format Selector -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="输出格式" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6" />
                        <ComboBox Text="{Binding Format}" Padding="8,6" Background="{StaticResource BgSecondaryBrush}"
                                  BorderBrush="{StaticResource BorderBrush}">
                            <ComboBoxItem>mp4</ComboBoxItem><ComboBoxItem>mkv</ComboBoxItem>
                            <ComboBoxItem>avi</ComboBoxItem><ComboBoxItem>mov</ComboBoxItem>
                            <ComboBoxItem>webm</ComboBoxItem><ComboBoxItem>flv</ComboBoxItem><ComboBoxItem>wmv</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="16" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="码率" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6" />
                            <ComboBox Text="{Binding Bitrate}" Padding="8,6" Background="{StaticResource BgSecondaryBrush}" BorderBrush="{StaticResource BorderBrush}">
                                <ComboBoxItem>1M</ComboBoxItem><ComboBoxItem>2M</ComboBoxItem><ComboBoxItem>4M</ComboBoxItem><ComboBoxItem>8M</ComboBoxItem><ComboBoxItem>16M</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="CRF" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6" />
                            <ComboBox Text="{Binding Crf}" Padding="8,6" Background="{StaticResource BgSecondaryBrush}" BorderBrush="{StaticResource BorderBrush}">
                                <ComboBoxItem>18</ComboBoxItem><ComboBoxItem>23</ComboBoxItem><ComboBoxItem>28</ComboBoxItem><ComboBoxItem>32</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="16" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="分辨率" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6" />
                            <TextBox Text="{Binding Resolution}" Padding="8,6" Background="{StaticResource BgSecondaryBrush}"
                                     BorderBrush="{StaticResource BorderBrush}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="帧率" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6" />
                            <ComboBox Text="{Binding Fps}" Padding="8,6" Background="{StaticResource BgSecondaryBrush}" BorderBrush="{StaticResource BorderBrush}">
                                <ComboBoxItem></ComboBoxItem><ComboBoxItem>24</ComboBoxItem><ComboBoxItem>30</ComboBoxItem><ComboBoxItem>60</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <!-- Output Dir -->
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBox Text="{Binding OutputDir}" Padding="8,6" Background="{StaticResource BgSecondaryBrush}"
                                 BorderBrush="{StaticResource BorderBrush}" IsReadOnly="True" />
                        <Button Grid.Column="1" Content="浏览..." Command="{Binding BrowseOutputCommand}"
                                Padding="12,6" Margin="8,0,0,0" Background="{StaticResource BgSecondaryBrush}"
                                BorderBrush="{StaticResource BorderBrush}" Foreground="{StaticResource TextPrimaryBrush}">
                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6" /></Style></Button.Resources>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Progress -->
            <Border Visibility="{Binding Running, Converter={StaticResource BoolToVis}}"
                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="12" Margin="0,0,0,12" Background="{StaticResource BgCardBrush}">
                <StackPanel>
                    <TextBlock Text="{Binding ProgressText}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" Margin="0,0,0,6" />
                    <ProgressBar Value="{Binding Progress}" Height="6" />
                </StackPanel>
            </Border>

            <!-- Results -->
            <StackPanel Orientation="Horizontal" Visibility="{Binding Running, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" Margin="0,0,0,12">
                <TextBlock Foreground="{StaticResource SuccessBrush}" FontSize="13">
                    <Run Text="成功 " /><Run Text="{Binding SuccessCount}" /><Run Text=" 个" />
                </TextBlock>
                <TextBlock Margin="16,0,0,0" Foreground="{StaticResource ErrorBrush}" FontSize="13">
                    <Run Text="失败 " /><Run Text="{Binding FailCount}" /><Run Text=" 个" />
                </TextBlock>
            </StackPanel>

            <!-- Action Buttons -->
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                <Button Content="开始转换" Command="{Binding StartConvertCommand}"
                        Background="{StaticResource AccentDarkBrush}" Foreground="White"
                        BorderThickness="0" Padding="0,12">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="10" /></Style></Button.Resources>
                </Button>
                <Button Grid.Column="2" Content="取消" Command="{Binding CancelCommand}"
                        Visibility="{Binding Running, Converter={StaticResource BoolToVis}}"
                        Background="{StaticResource BgSecondaryBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                        BorderBrush="{StaticResource BorderBrush}" Padding="0,12">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="10" /></Style></Button.Resources>
                </Button>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
